# Copie para terraform.tfvars e preencha com seus valores.

proxmox_endpoint  = "https://10.26.7.10:8006"
proxmox_api_token = "user@pve!terraform=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"
proxmox_node      = "pve01"
proxmox_pool      = "researchers"   # GPU só está disponível para researchers

vm_name      = "ubuntu-gpu"
vm_cores     = 4
vm_memory    = 8192    # 8 GB (mínimo recomendado para GPU)
vm_disk_size = 64      # 64 GB (espaço para drivers NVIDIA + datasets)
iso_file     = "ubuntu-24.04.4-live-server-amd64.iso"

# GPU — escolha uma:
gpu_mapping = "gpu-rtx4060-01"    # Slot 1 (PCIe CPU — menor latência)
# gpu_mapping = "gpu-rtx4060-02"  # Slot 2 (PCIe Chipset)

# ── Etapa 2: Descomente após instalar o SO e obter o IP da VM ──
# vm_ssh_host        = "10.26.7.XXX"
# vm_ssh_user        = "ubuntu"
# vm_ssh_private_key = "~/.ssh/id_rsa"
# vm_sudo_password   = "senha-do-sudo"   # Deixe vazio se o usuário tem NOPASSWD
